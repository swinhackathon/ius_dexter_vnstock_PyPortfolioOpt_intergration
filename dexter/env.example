# LLM API Keys
OPENAI_API_KEY=your-api-key
ANTHROPIC_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
XAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-api-key
MOONSHOT_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Stock Market API Key
FINANCIAL_DATASETS_API_KEY=your-api-key

# Web Search API Keys (Exa → Perplexity → Tavily)
EXASEARCH_API_KEY=your-api-key
PERPLEXITY_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# LangSmith 
LANGSMITH_API_KEY=your-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=true

# HTTP Server
DEXTER_SERVER_PORT=3000

# Stock Advisory Tool (used internally by /ask)
VNSTOCK_API_URL=http://localhost:8050
DEXTER_ADVISORY_CACHE_TTL_MS=300000
DEXTER_ADVISORY_LOOKBACK_DAYS=180
DEXTER_ADVISORY_PROVIDER_TIMEOUT_MS=5000
DEXTER_ADVISORY_TIMEOUT_BUDGET_MS=12000
DEXTER_ADVISORY_PROVIDER_RETRIES=2
DEXTER_ADVISORY_MAX_SYMBOLS=6
DEXTER_ADVISORY_PYTHON_BIN=python
# Recommended for Vietnamese sector discovery stability:
# DEXTER_ADVISORY_PROVIDER_TIMEOUT_MS=10000
# DEXTER_ADVISORY_TIMEOUT_BUDGET_MS=35000
# DEXTER_ADVISORY_PROVIDER_RETRIES=1
# DEXTER_ADVISORY_MAX_SYMBOLS=4
DEXTER_ADVISORY_DEFAULT_SYMBOLS=
DEXTER_ADVISORY_PYTHON_TIMEOUT_MS=5000
DEXTER_ADVISORY_GEMINI_NLG_ENABLED=true
DEXTER_ADVISORY_GEMINI_NLG_MODEL=gemini-2.5-flash
DEXTER_ADVISORY_GEMINI_NLG_TIMEOUT_MS=30000
